<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_lms_lesson_attendance_notice" model="ir.cron">
        <field name="name">LMS: Lesson attendance emails (15 min before start)</field>
        <field name="model_id" ref="model_lms_lesson"/>
        <field name="state">code</field>
        <field name="code">model.cron_send_attendance_notices()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
