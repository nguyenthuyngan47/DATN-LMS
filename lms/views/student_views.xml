<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_student_search" model="ir.ui.view">
        <field name="name">lms.student.search</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="name"/>
                <field name="email"/>
                <filter string="My Account" name="my_account" domain="[('is_current_user_account', '=', True)]"/>
                <separator/>
                <filter string="Pending Approval" name="status_pending" domain="[('current_course_registration_status', '=', 'pending')]" invisible="not context.get('from_course_students')"/>
                <filter string="Approved" name="status_approved" domain="[('current_course_registration_status', '=', 'approved')]" invisible="not context.get('from_course_students')"/>
                <filter string="Learning" name="status_learning" domain="[('current_course_registration_status', '=', 'learning')]" invisible="not context.get('from_course_students')"/>
                <filter string="Completed" name="status_completed" domain="[('current_course_registration_status', '=', 'completed')]" invisible="not context.get('from_course_students')"/>
                <filter string="Rejected" name="status_rejected" domain="[('current_course_registration_status', '=', 'rejected')]" invisible="not context.get('from_course_students')"/>
            </search>
        </field>
    </record>

    <record id="view_lms_student_tree" model="ir.ui.view">
        <field name="name">lms.student.list</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <list
                string="Students"
                create="0"
                decoration-info="is_current_user_account"
                decoration-bf="is_current_user_account"
            >
                <field name="is_current_user_account" column_invisible="1"/>
                <field name="id" optional="show"/>
                <field name="name" optional="show"/>
                <field name="email" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="gender" optional="show"/>
                <field name="date_of_birth" optional="show"/>
                <field name="address" optional="show"/>
                <field name="is_active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_lms_student_tree_by_course" model="ir.ui.view">
        <field name="name">lms.student.list.by.course</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <list
                string="Course Students"
                create="0"
                delete="0"
                editable="bottom"
                decoration-info="is_current_user_account"
                decoration-bf="is_current_user_account"
            >
                <field name="is_current_user_account" column_invisible="1"/>
                <field name="id" optional="show"/>
                <field name="name" optional="show"/>
                <field
                    name="current_course_registration_status"
                    string="Registration Status"
                    widget="selection"
                    optional="show"
                    decoration-success="current_course_registration_status in ('approved', 'learning', 'completed')"
                    decoration-info="current_course_registration_status == 'pending'"
                    decoration-danger="current_course_registration_status == 'rejected'"
                    decoration-muted="current_course_registration_status == 'cancelled'"
                />
                <field name="email" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="gender" optional="show"/>
                <field name="date_of_birth" optional="show"/>
                <field name="address" optional="show"/>
                <field name="is_active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_lms_student_form" model="ir.ui.view">
        <field name="name">lms.student.form</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <form string="Student" create="0">
                <sheet>
                    <field name="is_instructor_restricted" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_roadmaps"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-graduation-cap"
                            invisible="is_instructor_restricted"
                        >
                            <field name="roadmap_ids" widget="statinfo" string="Roadmap"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Student"/>
                        <h1>
                            <field name="name" placeholder="Student name" readonly="is_instructor_restricted"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Contact">
                            <field name="email" readonly="is_instructor_restricted"/>
                            <field name="phone" readonly="is_instructor_restricted"/>
                            <field name="gender" readonly="is_instructor_restricted"/>
                            <field name="date_of_birth" readonly="is_instructor_restricted"/>
                        </group>
                        <group string="Account &amp; learning">
                            <field name="current_level" readonly="is_instructor_restricted"/>
                            <field name="is_active" readonly="is_instructor_restricted"/>
                            <field name="last_login" readonly="1"/>
                            <field
                                name="current_course_registration_status"
                                string="Registration Status"
                                invisible="not context.get('from_course_students')"
                                readonly="not context.get('from_course_students')"
                                required="context.get('from_course_students')"
                            />
                        </group>
                    </group>
                    <group>
                        <field name="address" colspan="2" readonly="is_instructor_restricted"/>
                    </group>
                    <separator string="Face template registration (attendance)" invisible="is_instructor_restricted"/>
                    <group name="face_biometric" col="1" invisible="is_instructor_restricted">
                        <field name="face_embedding_json" invisible="1"/>
                        <group>
                            <field name="face_embedding_registered_at" readonly="1"/>
                        </group>
                        <field name="face_enrollment_mount_html" widget="html" readonly="1" nolabel="1" colspan="2"/>
                    </group>
                    <notebook>
                        <page string="Learning Goals" name="goals">
                            <group>
                                <field name="learning_goals" placeholder="Enter learning goals..." readonly="is_instructor_restricted"/>
                                <field name="desired_skills" placeholder="Enter desired skills..." readonly="is_instructor_restricted"/>
                            </group>
                        </page>
                        <page string="Enrolled Courses" name="courses" invisible="is_instructor_restricted">
                            <field name="enrolled_courses_ids" nolabel="1">
                                <list>
                                    <field name="course_id" width="220px"/>
                                    <field name="enrollment_date" width="120px"/>
                                    <field name="status" width="120px"/>
                                    <field name="progress" widget="progressbar" width="120px"/>
                                </list>
                            </field>
                        </page>
                        <page string="Learning History" name="history" invisible="is_instructor_restricted">
                            <field name="learning_history_ids" nolabel="1" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="date" width="120px"/>
                                    <field name="course_id" width="200px"/>
                                    <field name="lesson_id" width="200px"/>
                                    <field name="study_duration" string="Duration (min)" width="120px"/>
                                    <field name="status" width="120px"/>
                                </list>
                            </field>
                        </page>
                        <!-- <page string="Statistics" name="statistics">
                            <group>
                                <group string="Overview">
                                    <field name="total_courses"/>
                                    <field name="completed_courses"/>
                                    <field name="learning_progress" widget="progressbar"/>
                                    <field name="learning_status"/>
                                    <field name="average_score"/>
                                    <field name="total_study_time"/>
                                </group>
                            </group>
                        </page> -->
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lms_student_kanban" model="ir.ui.view">
        <field name="name">lms.student.kanban</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <kanban default_group_by="current_level" class="o_kanban_dashboard">
                <field name="name"/>
                <field name="image_1920"/>
                <field name="current_level"/>
                <field name="total_courses"/>
                <field name="completed_courses"/>
                <field name="average_score"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('lms.student', 'image_1920', record.id.raw_value)" alt="Avatar"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong><field name="name"/></strong>
                                    <div><field name="email"/></div>
                                    <div>Level: <field name="current_level"/></div>
                                    <div>Courses: <field name="completed_courses"/>/<field name="total_courses"/></div>
                                    <div>Avg Score: <field name="average_score"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_lms_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">lms.student</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_lms_student_search"/>
    </record>

    <record id="action_lms_student_by_course" model="ir.actions.act_window">
        <field name="name">Course Students</field>
        <field name="res_model">lms.student</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="view_id" ref="view_lms_student_tree_by_course"/>
        <field name="search_view_id" ref="view_lms_student_search"/>
        <field name="domain">[('enrolled_courses_ids.course_id', '=', (context.get('course_id') or context.get('active_id')))]</field>
        <field name="context">{'from_course_students': 1}</field>
    </record>

    <record id="action_lms_student_set_status_pending" model="ir.actions.server">
        <field name="name">Set Status: Pending Approval</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_pending()</field>
    </record>

    <record id="action_lms_student_set_status_approved" model="ir.actions.server">
        <field name="name">Set Status: Approved</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_approved()</field>
    </record>

    <record id="action_lms_student_set_status_rejected" model="ir.actions.server">
        <field name="name">Set Status: Rejected</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_rejected()</field>
    </record>

    <record id="action_lms_student_set_status_learning" model="ir.actions.server">
        <field name="name">Set Status: Learning</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_learning()</field>
    </record>

    <record id="action_lms_student_set_status_completed" model="ir.actions.server">
        <field name="name">Set Status: Completed</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_completed()</field>
    </record>

</odoo>
