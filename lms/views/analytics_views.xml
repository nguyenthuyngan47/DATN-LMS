<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =========================================================
         Analytics: Enrollments (lms.student.course)
         ========================================================= -->

    <record id="view_lms_student_course_search_analytics" model="ir.ui.view">
        <field name="name">lms.student.course.search.analytics</field>
        <field name="model">lms.student.course</field>
        <field name="arch" type="xml">
            <search string="Enrollment Analysis">
                <field name="student_id"/>
                <field name="course_id"/>
                <field name="status"/>
                <field name="enrollment_date"/>
                <filter string="Pending Approval" name="status_pending" domain="[('status', '=', 'pending')]"/>
                <filter string="Learning" name="status_learning" domain="[('status', '=', 'learning')]"/>
                <filter string="Completed" name="status_completed" domain="[('status', '=', 'completed')]"/>
                <filter string="Rejected" name="status_rejected" domain="[('status', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Course" name="group_course" context="{'group_by': 'course_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_lms_student_course_tree_analytics" model="ir.ui.view">
        <field name="name">lms.student.course.list.analytics</field>
        <field name="model">lms.student.course</field>
        <field name="arch" type="xml">
            <list string="Enrollments">
                <field name="student_id"/>
                <field name="course_id"/>
                <field name="enrollment_date"/>
                <field name="status"/>
                <field name="progress" widget="progressbar"/>
                <field name="final_score"/>
            </list>
        </field>
    </record>

    <record id="view_lms_student_course_pivot_analytics" model="ir.ui.view">
        <field name="name">lms.student.course.pivot.analytics</field>
        <field name="model">lms.student.course</field>
        <field name="arch" type="xml">
            <pivot string="Pivot - Enrollments">
                <field name="course_id" type="row"/>
                <field name="status" type="col"/>
                <field name="progress" type="measure"/>
                <field name="final_score" type="measure"/>
                <field name="id" type="measure" string="Number of Enrollments"/>
            </pivot>
        </field>
    </record>

    <record id="view_lms_student_course_graph_analytics" model="ir.ui.view">
        <field name="name">lms.student.course.graph.analytics</field>
        <field name="model">lms.student.course</field>
        <field name="arch" type="xml">
            <graph string="Graph - Enrollments" type="bar">
                <field name="course_id" type="row"/>
                <field name="id" type="measure" string="Number of Enrollments"/>
                <field name="progress" type="measure"/>
                <field name="final_score" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_lms_analytics_student_course" model="ir.actions.act_window">
        <field name="name">Analytics - Enrollments</field>
        <field name="res_model">lms.student.course</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="search_view_id" ref="view_lms_student_course_search_analytics"/>
    </record>

    <!-- =========================================================
         Analytics: Learning History (lms.learning.history)
         ========================================================= -->

    <record id="view_lms_learning_history_pivot_analytics" model="ir.ui.view">
        <field name="name">lms.learning.history.pivot.analytics</field>
        <field name="model">lms.learning.history</field>
        <field name="arch" type="xml">
            <pivot string="Pivot - Learning History">
                <field name="date" interval="day" type="row"/>
                <field name="course_id" type="row"/>
                <field name="status" type="col"/>
                <field name="study_duration" type="measure"/>
                <field name="analytics_count" type="measure" string="Number of Study Sessions"/>
            </pivot>
        </field>
    </record>

    <record id="view_lms_learning_history_graph_analytics" model="ir.ui.view">
        <field name="name">lms.learning.history.graph.analytics</field>
        <field name="model">lms.learning.history</field>
        <field name="arch" type="xml">
            <graph string="Graph - Learning History" type="line">
                <field name="date" interval="day" type="row"/>
                <field name="study_duration" type="measure"/>
                <field name="analytics_count" type="measure" string="Number of Study Sessions"/>
            </graph>
        </field>
    </record>

    <record id="action_lms_analytics_learning_history" model="ir.actions.act_window">
        <field name="name">Analytics - Learning History</field>
        <field name="res_model">lms.learning.history</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="search_view_id" ref="view_lms_learning_history_search"/>
    </record>

</odoo>

