<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Course Category -->
    <record id="view_lms_course_category_tree" model="ir.ui.view">
        <field name="name">lms.course.category.list</field>
        <field name="model">lms.course.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name" width="200px"/>
                <field name="description" width="320px"/>
            </list>
        </field>
    </record>

    <record id="view_lms_course_category_form" model="ir.ui.view">
        <field name="name">lms.course.category.form</field>
        <field name="model">lms.course.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Course Level -->
    <record id="view_lms_course_level_tree" model="ir.ui.view">
        <field name="name">lms.course.level.list</field>
        <field name="model">lms.course.level</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_lms_course_search" model="ir.ui.view">
        <field name="name">lms.course.search</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <search string="Search Courses">
                <field name="name" string="Course Name"/>
                <field name="category_id"/>
                <field name="level_id"/>
                <field name="instructor_id"/>
                <field name="tag_ids"/>
                <filter string="Published" name="published" domain="[('state', '=', 'published')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <separator/>
                <filter
                    string="My Courses"
                    name="my_courses"
                    domain="[('instructor_id', '=', uid)]"
                    groups="lms.group_lms_instructor"
                />
                <filter
                    string="My Courses"
                    name="my_enrolled_courses"
                    domain="[
                        ('student_course_ids.student_id.user_id', '=', uid),
                        ('student_course_ids.status', '!=', 'rejected'),
                    ]"
                    groups="lms.group_lms_user"
                />
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Level" name="group_level" context="{'group_by': 'level_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Instructor" name="group_instructor" context="{'group_by': 'instructor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Course -->
    <record id="view_lms_course_tree" model="ir.ui.view">
        <field name="name">lms.course.list</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <list string="Courses" decoration-info="state=='published'" decoration-muted="state=='archived'">
                <header>
                    <button
                        name="%(action_lms_student_ai_chat)d"
                        string="Roadmap Consultation for Students"
                        type="action"
                        class="btn-secondary"
                        display="always"
                        groups="lms.group_lms_user"
                    />
                </header>
                <field name="state" column_invisible="1"/>
                <field name="name" width="240px"/>
                <field name="instructor_id" width="180px"/>
                <field name="category_id" width="150px"/>
                <field name="start_date" width="120px"/>
                <field name="end_date" width="120px"/>
                <field name="enrolled_students_count" width="100px"/>
            </list>
        </field>
    </record>

    <record id="view_lms_course_form" model="ir.ui.view">
        <field name="name">lms.course.form</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <header>
                    <!-- <button name="action_publish" string="Publish" type="object" class="btn-primary" modifiers="{'invisible': [('state', '!=', 'draft')]}"/> -->
                    <button
                        name="action_register_courses"
                        string="Enroll in Course"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'published' or not is_active or not show_register_button"
                    />
                    <button
                        name="action_cancel_course_registration"
                        string="Cancel Enrollment"
                        type="object"
                        class="btn-secondary"
                        invisible="state != 'published' or not show_cancel_button"
                    />
                </header>
                <sheet>
                    <field name="is_student_course_readonly" invisible="1"/>
                    <field name="show_register_button" invisible="1"/>
                    <field name="show_cancel_button" invisible="1"/>
                    <field name="show_learning_content_tabs" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="%(action_lms_student_by_course)d"
                            type="action"
                            class="oe_stat_button"
                            icon="fa-users"
                            context="{'course_id': id, 'from_course_students': 1, 'form_view_initial_mode': 'edit'}"
                        >
                            <field name="enrolled_students_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Published" bg_color="text-bg-success" invisible="state != 'published'"/>
                    <group>
                        <group>
                            <field name="name" readonly="is_student_course_readonly"/>
                            <field name="state" readonly="is_student_course_readonly"/>
                            <field name="is_active" readonly="is_student_course_readonly"/>
                            <field name="price" string="Cost (VND)" readonly="is_student_course_readonly"/>
                        </group>
                        <group>
                            <field name="category_id" readonly="is_student_course_readonly"/>
                            <field name="level_id" readonly="is_student_course_readonly"/>
                            <field name="instructor_id" readonly="is_student_course_readonly" domain="[('groups_id', 'in', [%(lms.group_lms_instructor)d]), ('share', '=', False), ('active', '=', True)]"/>
                            <field name="duration_hours" readonly="is_student_course_readonly"/>
                            <field name="total_lessons" readonly="is_student_course_readonly"/>
                        </group>
                    </group>
                    <group>
                        <field name="contact_payment" colspan="2" readonly="is_student_course_readonly" placeholder="Phone, Zalo, Facebook, Email..."/>
                    </group>
                    <group string="Course period" name="course_period">
                        <field name="start_date" readonly="is_student_course_readonly"/>
                        <field name="end_date" readonly="is_student_course_readonly"/>
                    </group>
                    <notebook>
                        <page string="Lessons" name="lessons" invisible="not show_learning_content_tabs">
                            <!-- no_open: only open lesson via Details button → action_open_lesson_full (no JS). -->
                            <field name="lesson_ids" nolabel="1" readonly="is_student_course_readonly">
                                <list no_open="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="current_user_lesson_locked" column_invisible="1"/>
                                    <field name="current_user_lesson_lock_message" column_invisible="1"/>
                                    <field name="name" string="Lesson" width="140px"/>
                                    <field name="start_datetime" string="Start" width="170px"/>
                                    <field name="end_datetime" string="End" width="170px"/>
                                    <field name="duration_minutes" string="Duration (min)" width="120px"/>
                                    <field
                                        name="current_user_lesson_progress_label"
                                        string="Attendance"
                                        optional="show"
                                        width="110px"
                                    />
                                    <button
                                        name="action_open_lesson_full"
                                        type="object"
                                        string="Details"
                                        class="btn-link"
                                        icon="fa-external-link"
                                        title="Open Lesson Full Screen"
                                        width="90px"
                                        invisible="current_user_lesson_locked"
                                    />
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field
                                name="description"
                                readonly="is_student_course_readonly"
                                placeholder="Enter course overview, learning objectives, syllabus, and notes for students..."
                            />
                        </page>
                        <page string="Prerequisites" name="prerequisites">
                            <field
                                name="prerequisite_ids"
                                widget="many2many_tags"
                                readonly="is_student_course_readonly"
                                placeholder="Select courses students must complete before enrolling in this course..."
                            />
                        </page>
                        <page string="Tags" name="tags" invisible="not show_learning_content_tabs">
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" readonly="is_student_course_readonly"/>
                        </page>
                        
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lms_course_kanban" model="ir.ui.view">
        <field name="name">lms.course.kanban</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id" class="o_kanban_dashboard">
                <field name="name"/>
                <field name="image_1920"/>
                <field name="category_id"/>
                <field name="level_id"/>
                <field name="duration_hours"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="enrolled_students_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('lms.course', 'image_1920', record.id.raw_value)" alt="Course"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong><field name="name"/></strong>
                                    <div><field name="category_id"/> - <field name="level_id"/></div>
                                    <div>Duration: <field name="duration_hours"/> hours</div>
                                    <div><field name="start_date"/> – <field name="end_date"/></div>
                                    <div>Students: <field name="enrolled_students_count"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_lms_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">lms.course</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_lms_course_search"/>
    </record>

    <record id="action_lms_course_student" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">lms.course</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_lms_course_search"/>
        <field name="context">{'search_default_my_enrolled_courses': 1}</field>
    </record>

    <record id="action_lms_course_instructor" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">lms.course</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_lms_course_search"/>
        <field name="context">{'search_default_my_courses': 1}</field>
    </record>

    <record id="action_lms_course_register" model="ir.actions.server">
        <field name="name">Enroll in Course</field>
        <field name="model_id" ref="model_lms_course"/>
        <field name="binding_model_id" ref="model_lms_course"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_register_courses()</field>
    </record>

    <record id="action_lms_course_category" model="ir.actions.act_window">
        <field name="name">Course Categories</field>
        <field name="res_model">lms.course.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_lms_course_level_form" model="ir.ui.view">
        <field name="name">lms.course.level.form</field>
        <field name="model">lms.course.level</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_course_level" model="ir.actions.act_window">
        <field name="name">Course Levels</field>
        <field name="res_model">lms.course.level</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_lms_course_tag_tree" model="ir.ui.view">
        <field name="name">lms.course.tag.list</field>
        <field name="model">lms.course.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_lms_course_tag" model="ir.actions.act_window">
        <field name="name">Course Tags</field>
        <field name="res_model">lms.course.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Lesson form when opened from Course tab (full page, no dialog); readonly for students -->
    <record id="view_lms_lesson_course_tab_form" model="ir.ui.view">
        <field name="name">lms.lesson.course.tab.form</field>
        <field name="model">lms.lesson</field>
        <!-- Low priority (1) = default form when opening lesson from course; calendar uses view_lms_lesson_calendar_form via form_view_id. -->
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Lesson" delete="0">
                <sheet>
                    <field name="course_form_readonly" invisible="1"/>
                    <field name="current_user_lesson_locked" invisible="1"/>
                    <field name="current_user_lesson_lock_message" invisible="1"/>
                    <field name="video_filename" invisible="1"/>

                    <div
                        class="alert alert-warning mb-3"
                        role="alert"
                        invisible="not current_user_lesson_locked"
                    >
                        <field name="current_user_lesson_lock_message" nolabel="1" readonly="1"/>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Lesson Name"/>
                        <h1>
                            <field
                                name="name"
                                placeholder="E.g.: Lesson 1 - Course Introduction"
                                readonly="course_form_readonly"
                            />
                        </h1>
                    </div>

                    <group>
                        <group string="Lesson Information">
                            <field name="sequence" readonly="course_form_readonly"/>
                            <field name="lesson_type" readonly="course_form_readonly"/>
                            <field name="state" readonly="course_form_readonly"/>
                        </group>
                        <group string="Schedule">
                            <field name="start_datetime" readonly="course_form_readonly"/>
                            <field name="duration_minutes" readonly="course_form_readonly"/>
                            <field name="end_datetime" readonly="1"/>
                        </group>
                    </group>

                    <group
                        string="Online Session"
                        invisible="lesson_type != 'online'"
                        groups="lms.group_lms_instructor,lms.group_lms_manager,base.group_system"
                    >
                        <group>
                            <field
                                name="meeting_url"
                                widget="url"
                                placeholder="https://meet.google.com/..."
                            />
                            <field name="calendar_sync_status" readonly="1"/>
                        </group>
                        <group>
                            <field
                                name="calendar_sync_error"
                                readonly="1"
                                invisible="calendar_sync_status != 'error'"
                            />
                        </group>
                    </group>

                    <notebook>
                        <page
                            string="My Progress"
                            name="my_progress"
                            invisible="lesson_type == 'online' or not course_form_readonly"
                        >
                            <group string="Learning Status">
                                <field
                                    name="current_user_progress_percent"
                                    widget="progressbar"
                                    readonly="1"
                                />
                                <field name="current_user_status" readonly="1"/>
                            </group>
                        </page>

                        <page
                            string="Face Attendance"
                            name="face_attendance"
                            invisible="lesson_type != 'online' or not course_form_readonly"
                        >
                            <group>
                                <field
                                    name="current_user_face_checked_in"
                                    readonly="1"
                                    string="Face Attendance Checked"
                                />
                            </group>
                            <field
                                name="face_lesson_attendance_mount_html"
                                widget="html"
                                readonly="1"
                                nolabel="1"
                            />
                        </page>

                        <page string="Materials" name="materials">
                            <group>
                                <group string="Lecture Video" invisible="lesson_type != 'video'">
                                    <field
                                        name="video_upload_hint_html"
                                        widget="html"
                                        readonly="1"
                                        nolabel="1"
                                        colspan="2"
                                    />
                                    <field
                                        name="video_attachment"
                                        filename="video_filename"
                                        readonly="course_form_readonly"
                                        invisible="course_form_readonly"
                                    />
                                    <field
                                        name="video_preview_html"
                                        widget="html"
                                        readonly="1"
                                        nolabel="1"
                                        colspan="2"
                                    />
                                </group>
                                <group string="PDF Materials">
                                    <field
                                        name="pdf_attachment"
                                        filename="pdf_filename"
                                        readonly="course_form_readonly"
                                    />
                                </group>
                            </group>
                        </page>

                        <page string="Description" name="description">
                            <field
                                name="description"
                                nolabel="1"
                                readonly="course_form_readonly"
                                placeholder="Lesson content, objectives, notes for students..."
                            />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Calendar popup form must load before calendar view (form_view_id). -->
    <record id="view_lms_lesson_calendar_form" model="ir.ui.view">
        <field name="name">lms.lesson.calendar.form</field>
        <field name="model">lms.lesson</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Lesson" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Lesson Name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Lesson Information">
                            <field name="course_id" readonly="1"/>
                            <field name="lesson_type" readonly="1"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group string="Schedule">
                            <field name="start_datetime" readonly="1"/>
                            <field name="duration_minutes" readonly="1"/>
                            <field name="end_datetime" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lms_lesson_student_calendar" model="ir.ui.view">
        <field name="name">lms.lesson.student.calendar</field>
        <field name="model">lms.lesson</field>
        <field name="arch" type="xml">
            <calendar
                string="Schedule"
                date_start="start_datetime"
                date_stop="end_datetime"
                color="calendar_color"
                event_open_popup="1"
                form_view_id="%(lms.view_lms_lesson_calendar_form)d"
                quick_create="0"
                create="0"
                edit="0"
                delete="0"
            >
                <field name="name"/>
                <field name="calendar_color"/>
                <field name="course_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="action_lms_student_lesson_calendar" model="ir.actions.act_window">
        <field name="name">Schedule</field>
        <field name="res_model">lms.lesson</field>
        <field name="view_mode">calendar</field>
        <field name="domain">
            [
                ('course_id.student_course_ids.student_id.user_id', '=', uid),
                ('state', '!=', 'draft')
            ]
        </field>
        <field name="context">
            {
                'form_view_initial_mode': 'readonly',
                'create': 0,
                'edit': 0,
                'delete': 0
            }
        </field>
        <field name="groups_id" eval="[(4, ref('lms.group_lms_user'))]"/>
    </record>
    <record id="action_lms_student_lesson_calendar_view_calendar" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="view_lms_lesson_student_calendar"/>
        <field name="act_window_id" ref="action_lms_student_lesson_calendar"/>
    </record>

    <record id="action_lms_instructor_lesson_calendar" model="ir.actions.act_window">
        <field name="name">Teaching Schedule</field>
        <field name="res_model">lms.lesson</field>
        <field name="view_mode">calendar</field>
        <field name="domain">
            [
                ('course_id.instructor_id', '=', uid),
                ('state', '!=', 'draft')
            ]
        </field>
        <field name="context">
            {
                'form_view_initial_mode': 'readonly',
                'create': 0,
                'edit': 0,
                'delete': 0
            }
        </field>
        <field name="groups_id" eval="[(4, ref('lms.group_lms_instructor'))]"/>
    </record>
    <record id="action_lms_instructor_lesson_calendar_view_calendar" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="view_lms_lesson_student_calendar"/>
        <field name="act_window_id" ref="action_lms_instructor_lesson_calendar"/>
    </record>
</odoo>
