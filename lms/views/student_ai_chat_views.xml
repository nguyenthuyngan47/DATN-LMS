<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_student_ai_chat_form" model="ir.ui.view">
        <field name="name">lms.student.ai.chat.form</field>
        <field name="model">lms.student.ai.chat</field>
        <field name="arch" type="xml">
            <form string="Roadmap Consultation for Students" create="0" edit="1" delete="0">
                <sheet>
                    <group>
                        <field name="title" readonly="1"/>
                        <field name="student_id" readonly="1"/>
                        <field name="question_target" readonly="1"/>
                        <field name="session_state" readonly="1"/>
                        <field name="has_available_courses" invisible="1"/>
                        <field name="unavailable_reason" invisible="1"/>
                        <field name="roadmap_options_json" invisible="1"/>
                        <field name="selected_roadmap_index" invisible="1"/>
                        <field name="created_roadmap_id" invisible="1"/>
                        <field name="has_roadmap_options" invisible="1"/>
                        <field name="has_roadmap_selected" invisible="1"/>
                        <field name="roadmap_option_1_available" invisible="1"/>
                        <field name="roadmap_option_2_available" invisible="1"/>
                        <field name="roadmap_option_3_available" invisible="1"/>
                        <field name="roadmap_option_1_label" invisible="1"/>
                        <field name="roadmap_option_2_label" invisible="1"/>
                        <field name="roadmap_option_3_label" invisible="1"/>
                        <field name="debug_last_ai_request" invisible="1"/>
                        <field name="debug_last_ai_response" invisible="1"/>
                    </group>
                    <group string="Setup Consultation Session">
                        <div
                            class="o_form_label text-warning"
                            invisible="has_available_courses"
                        >
                            The system currently has no courses; the roadmap consultation feature cannot be used.
                        </div>
                        <div
                            class="o_form_label text-info"
                            invisible="not has_available_courses"
                        >
                            Allowing AI to access personal data will improve analysis quality and provide a more suitable roadmap.
                        </div>
                        <field name="allow_personal_data"/>
                        <button
                            name="action_start_session"
                            string="Start Consultation"
                            type="object"
                            class="btn-primary"
                            invisible="session_state != 'draft'"
                        />
                    </group>
                    <group string="Chat" col="1">
                        <field name="conversation_html" widget="html" readonly="1" nolabel="1"/>
                        <field
                            name="user_message"
                            placeholder="Type your answer here then press Send (Enter)..."
                            nolabel="1"
                            invisible="session_state != 'chatting' or is_chat_locked"
                        />
                        <button
                            name="action_send_message"
                            string="Send (Enter)"
                            type="object"
                            class="btn-primary"
                            invisible="session_state != 'chatting' or is_chat_locked"
                        />
                        <div
                            class="o_form_label text-muted"
                            invisible="not is_chat_locked"
                        >
                            The consultation session is complete; chat has been locked.
                        </div>
                        <group
                            string="Roadmap Options to Choose"
                            invisible="session_state != 'done' or not has_roadmap_options"
                            col="1"
                        >
                            <div invisible="not roadmap_option_1_available" style="margin-bottom:10px;">
                                <field name="roadmap_option_1_html" widget="html" readonly="1" nolabel="1"/>
                                <button
                                    name="action_select_roadmap_1"
                                    string="Select Roadmap 1"
                                    type="object"
                                    class="btn-primary mt-2"
                                    invisible="not roadmap_option_1_available or has_roadmap_selected"
                                />
                            </div>
                            <div invisible="not roadmap_option_2_available" style="margin-bottom:10px;">
                                <field name="roadmap_option_2_html" widget="html" readonly="1" nolabel="1"/>
                                <button
                                    name="action_select_roadmap_2"
                                    string="Select Roadmap 2"
                                    type="object"
                                    class="btn-primary mt-2"
                                    invisible="not roadmap_option_2_available or has_roadmap_selected"
                                />
                            </div>
                            <div invisible="not roadmap_option_3_available" style="margin-bottom:10px;">
                                <field name="roadmap_option_3_html" widget="html" readonly="1" nolabel="1"/>
                                <button
                                    name="action_select_roadmap_3"
                                    string="Select Roadmap 3"
                                    type="object"
                                    class="btn-primary mt-2"
                                    invisible="not roadmap_option_3_available or has_roadmap_selected"
                                />
                            </div>
                            <div class="o_form_label text-success" invisible="not has_roadmap_selected">
                                You have selected a roadmap. Open it to register for each course (pending lecturer/admin approval).
                            </div>
                            <button
                                name="action_open_created_roadmap"
                                string="Open My Roadmap"
                                type="object"
                                class="btn-secondary mt-2"
                                invisible="not has_roadmap_selected"
                            />
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_lms_student_ai_chat" model="ir.actions.act_window">
        <field name="name">Roadmap Consultation for Students</field>
        <field name="res_model">lms.student.ai.chat</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_lms_student_ai_chat_form"/>
        <field name="target">current</field>
        <field name="groups_id" eval="[(4, ref('lms.group_lms_user'))]"/>
    </record>
</odoo>
