<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_lecturer_list" model="ir.ui.view">
        <field name="name">lms.lecturer.list</field>
        <field name="model">lms.lecturer</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="id" width="70px"/>
                <field name="full_name" width="180px"/>
                <field name="email" width="220px"/>
                <field name="phone_number" width="130px"/>
                <field name="academic_degree" width="160px"/>
                <field name="years_of_experience" width="120px"/>
                <field name="status" string="Status" width="120px"/>
            </list>
        </field>
    </record>

    <record id="view_lms_lecturer_form" model="ir.ui.view">
        <field name="name">lms.lecturer.form</field>
        <field name="model">lms.lecturer</field>
        <field name="arch" type="xml">
            <form create="0">
                <sheet>
                    <group string="Identity &amp; account">
                        <group string="Profile">
                            <field name="lecturer_id" readonly="1"/>
                            <field name="full_name"/>
                            <field name="role" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group string="Contact &amp; login">
                            <field name="username" readonly="1"/>
                            <field name="email"/>
                            <field name="phone_number"/>
                            <field name="last_login" readonly="1"/>
                        </group>
                    </group>
                    <group string="Personal details">
                        <group string="Demographics">
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" colspan="2"/>
                    </group>
                    <group string="Academic background">
                        <group>
                            <field name="specialization"/>
                            <field name="academic_degree"/>
                            <field name="years_of_experience"/>
                        </group>
                        <group string="Teaching mode">
                            <field name="teaching_level"/>
                            <field name="teaching_type"/>
                        </group>
                    </group>
                    <group string="Teaching profile">
                        <field name="subject_expertise" colspan="2"/>
                        <field name="certifications" colspan="2"/>
                    </group>
