<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_roadmap_tree" model="ir.ui.view">
        <field name="name">lms.roadmap.list</field>
        <field name="model">lms.roadmap</field>
        <field name="arch" type="xml">
            <list string="Roadmap" decoration-info="state=='suggested'" decoration-success="state=='approved'" decoration-muted="state=='rejected'">
                <field name="name" width="220px"/>
                <field name="student_id" width="180px"/>
                <field name="total_courses" width="100px"/>
                <field name="recommendation_method" width="160px"/>
                <field name="state" width="120px"/>
                <field name="create_date" width="150px"/>
            </list>
        </field>
    </record>

    <record id="view_lms_roadmap_form" model="ir.ui.view">
        <field name="name">lms.roadmap.form</field>
        <field name="model">lms.roadmap</field>
        <field name="arch" type="xml">
            <form string="Recommended Roadmap">
                <header>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" modifiers="{'invisible': [('state', 'in', ['approved', 'locked', 'rejected'])]}" groups="lms.group_lms_manager,lms.group_lms_instructor,base.group_system"/>
                    <button name="action_lock" string="Lock" type="object" modifiers="{'invisible': [('state', 'in', ['locked', 'rejected'])]}" groups="lms.group_lms_manager,lms.group_lms_instructor,base.group_system"/>
                    <button name="action_reject" string="Reject" type="object" modifiers="{'invisible': [('state', 'in', ['rejected', 'locked'])]}" groups="lms.group_lms_manager,lms.group_lms_instructor,base.group_system"/>
                </header>
                <sheet>
                    <div class="alert alert-info mb-3" role="alert" invisible="state != 'suggested'">
                        Register for each course in the <b>Recommended Courses</b> tab using the <b>Enroll</b> button.
                        Each registration stays <b>Pending approval</b> until an instructor or administrator approves it.
                    </div>
                    <widget name="web_ribbon" title="Approved" bg_color="text-bg-success" invisible="state != 'approved'"/>
                    <widget name="web_ribbon" title="Locked" bg_color="text-bg-warning" invisible="state != 'locked'"/>
                    <widget name="web_ribbon" title="Rejected" bg_color="text-bg-danger" invisible="state != 'rejected'"/>
                    <div class="oe_title">
                        <label for="name" string="Roadmap"/>
                        <h1><field name="name" readonly="1" placeholder="Roadmap..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="state"/>
                            <field name="recommendation_method"/>
                        </group>
                        <group>
                            <field name="create_date"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                            <field name="reviewed_by"/>
                            <field name="review_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="ai_recommendation_reason" placeholder="AI recommendation reason..." nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Recommended Courses" name="courses">
                            <field name="course_line_ids" nolabel="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="course_id" width="220px"/>
                                    <field name="priority" width="100px"/>
                                    <field name="timeframe" width="120px"/>
                                    <field name="status" width="120px"/>
                                    <field name="enrollment_status" width="150px"/>
                                    <field name="show_enroll_button" column_invisible="1"/>
                                    <field name="similarity_score" widget="progressbar" optional="hide"/>
                                    <button
                                        name="action_enroll"
                                        string="Enroll"
                                        type="object"
                                        class="btn-primary"
                                        invisible="not show_enroll_button"
                                    />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="course_id"/>
                                                <field name="sequence"/>
                                                <field name="priority"/>
                                                <field name="timeframe"/>
                                                <field name="status"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="recommendation_reason" placeholder="Recommendation reason..."/>
                                            <field name="similarity_score"/>
                                        </group>
                                        <group>
                                            <field name="supplementary_materials" placeholder="Supplementary materials..."/>
                                            <field name="reminder_date"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Statistics" name="statistics">
                            <group>
                                <group string="Overview">
                                    <field name="total_courses"/>
                                    <field name="short_term_courses"/>
                                    <field name="medium_term_courses"/>
                                    <field name="long_term_courses"/>
                                </group>
                                <group string="Progress">
                                    <field name="completed_courses_count"/>
                                    <field name="in_progress_courses_count"/>
                                </group>
                            </group>
                        </page>
                        <page string="Review" name="review" modifiers="{'invisible': [('reviewed_by', '=', False)]}">
                            <group>
                                <field name="reviewed_by"/>
                                <field name="review_date"/>
                                <field name="review_notes" placeholder="Review notes..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lms_roadmap_kanban" model="ir.ui.view">
        <field name="name">lms.roadmap.kanban</field>
        <field name="model">lms.roadmap</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_dashboard">
                <field name="name"/>
                <field name="student_id"/>
                <field name="total_courses"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="student_id"/></div>
                                <div>Courses: <field name="total_courses"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_lms_roadmap" model="ir.actions.act_window">
        <field name="name">Recommended Roadmaps</field>
        <field name="res_model">lms.roadmap</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
