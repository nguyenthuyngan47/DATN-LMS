#. module: lms
#: model:mail.template,body_html:lms.email_template_lesson_attendance_link
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;\">\n"
"                <tr>\n"
"                    <td align=\"center\">\n"
"                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:640px;max-width:94%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;\">\n"
"                            <tr>\n"
"                                <td style=\"background:#0ea5e9;color:#ffffff;padding:18px 24px;font-size:18px;font-weight:700;\">\n"
"                                    LMS - Online Lesson Attendance Link\n"
"                                </td>\n"
"                            </tr>\n"
"                            <tr>\n"
"                                <td style=\"padding:24px;font-size:14px;line-height:1.7;\">\n"
"                                    <p style=\"margin:0 0 12px 0;\">\n"
"                                        You have a new online lesson in the course\n"
"                                        <strong><t t-out=\"object.course_id.name\"/></strong>.\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 12px 0;\">\n"
"                                        Lesson: <strong><t t-out=\"object.name\"/></strong>\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 18px 0;\">\n"
"                                        Please open the link below to go to the lesson page and mark your attendance:\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 22px 0;\">\n"
"                                        <a t-att-href=\"ctx.get('attendance_url')\" style=\"display:inline-block;background:#0ea5e9;color:#ffffff;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;\">\n"
"                                            Open Attendance Page\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:0;color:#6b7280;font-size:13px;\">\n"
"                                        If the button is not displayed, please visit:\n"
"                                        <a t-att-href=\"ctx.get('attendance_url')\">\n"
"                                            <t t-out=\"ctx.get('attendance_url')\"/>\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:18px 0 0 0;\">Best regards,<br/>LMS Administration Team</p>\n"
"                                </td>\n"
"                            </tr>\n"
"                        </table>\n"
"                    </td>\n"
"                </tr>\n"
"            </table>\n"
"        "
msgstr ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;\">\n"
"                <tr>\n"
"                    <td align=\"center\">\n"
"                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:640px;max-width:94%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;\">\n"
"                            <tr>\n"
"                                <td style=\"background:#0ea5e9;color:#ffffff;padding:18px 24px;font-size:18px;font-weight:700;\">\n"
"                                    LMS - Link điểm danh buổi học online\n"
"                                </td>\n"
"                            </tr>\n"
"                            <tr>\n"
"                                <td style=\"padding:24px;font-size:14px;line-height:1.7;\">\n"
"                                    <p style=\"margin:0 0 12px 0;\">\n"
"                                        Bạn có buổi học online mới trong khóa\n"
"                                        <strong><t t-out=\"object.course_id.name\"/></strong>.\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 12px 0;\">\n"
"                                        Bài học: <strong><t t-out=\"object.name\"/></strong>\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 18px 0;\">\n"
"                                        Vui lòng mở link bên dưới để vào trang bài học và điểm danh:\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 22px 0;\">\n"
"                                        <a t-att-href=\"ctx.get('attendance_url')\" style=\"display:inline-block;background:#0ea5e9;color:#ffffff;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;\">\n"
"                                            Mở trang điểm danh\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:0;color:#6b7280;font-size:13px;\">\n"
"                                        Nếu nút không hiển thị, vui lòng truy cập:\n"
"                                        <a t-att-href=\"ctx.get('attendance_url')\">\n"
"                                            <t t-out=\"ctx.get('attendance_url')\"/>\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:18px 0 0 0;\">Trân trọng,<br/>Ban quản trị LMS</p>\n"
"                                </td>\n"
"                            </tr>\n"
"                        </table>\n"
"                    </td>\n"
"                </tr>\n"
"            </table>\n"
"        "

#. module: lms
#: model:mail.template,body_html:lms.email_template_student_welcome
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;\">\n"
"                <tr>\n"
"                    <td align=\"center\">\n"
"                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:640px;max-width:94%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;\">\n"
"                            <tr>\n"
"                                <td style=\"background:#0ea5e9;color:#ffffff;padding:18px 24px;font-size:18px;font-weight:700;\">\n"
"                                    LMS - Student Account Activation Notice\n"
"                                </td>\n"
"                            </tr>\n"
"                            <tr>\n"
"                                <td style=\"padding:24px;font-size:14px;line-height:1.7;\">\n"
"                                    <p style=\"margin:0 0 12px 0;\">Dear <strong><t t-out=\"object.name or object.login\"/></strong>,</p>\n"
"                                    <p style=\"margin:0 0 12px 0;\">\n"
"                                        Your student account has been approved and successfully activated on the LMS system.\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 18px 0;\">\n"
"                                        You can log in to start learning today.\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 22px 0;\">\n"
"                                        <a t-att-href=\"(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')\" style=\"display:inline-block;background:#0ea5e9;color:#ffffff;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;\">\n"
"                                            Log In to System\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:0;color:#6b7280;font-size:13px;\">\n"
"                                        If the button is not displayed, please visit:\n"
"                                        <a t-att-href=\"(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')\">\n"
"                                            <t t-out=\"(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')\"/>\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:18px 0 0 0;\">Best regards,<br/>LMS Administration Team</p>\n"
"                                </td>\n"
"                            </tr>\n"
"                        </table>\n"
"                    </td>\n"
"                </tr>\n"
"            </table>\n"
"        "
msgstr ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;\">\n"
"                <tr>\n"
"                    <td align=\"center\">\n"
"                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:640px;max-width:94%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;\">\n"
"                            <tr>\n"
"                                <td style=\"background:#0ea5e9;color:#ffffff;padding:18px 24px;font-size:18px;font-weight:700;\">\n"
"                                    LMS - Thông báo kích hoạt tài khoản học viên\n"
"                                </td>\n"
"                            </tr>\n"
"                            <tr>\n"
"                                <td style=\"padding:24px;font-size:14px;line-height:1.7;\">\n"
"                                    <p style=\"margin:0 0 12px 0;\">Kính chào <strong><t t-out=\"object.name or object.login\"/></strong>,</p>\n"
"                                    <p style=\"margin:0 0 12px 0;\">\n"
"                                        Tài khoản học viên của bạn đã được phê duyệt và kích hoạt thành công trên hệ thống LMS.\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 18px 0;\">\n"
"                                        Bạn có thể đăng nhập để bắt đầu học tập ngay hôm nay.\n"
"                                    </p>\n"
"                                    <p style=\"margin:0 0 22px 0;\">\n"
"                                        <a t-att-href=\"(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')\" style=\"display:inline-block;background:#0ea5e9;color:#ffffff;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;\">\n"
"                                            Đăng nhập hệ thống\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:0;color:#6b7280;font-size:13px;\">\n"
"                                        Nếu nút không hiển thị, vui lòng truy cập:\n"
"                                        <a t-att-href=\"(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')\">\n"
"                                            <t t-out=\"(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')\"/>\n"
"                                        </a>\n"
"                                    </p>\n"
"                                    <p style=\"margin:18px 0 0 0;\">Trân trọng,<br/>Ban quản trị LMS</p>\n"
"                                </td>\n"
"                            </tr>\n"
"                        </table>\n"
"                    </td>\n"
"                </tr>\n"
"            </table>\n"
"        "

#. module: lms
#: model:mail.template,body_html:lms.email_template_lecturer_welcome
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;\">\n"
"                <tr>\n"
"                    <td align=\"center\">\n"
